generator client {
  provider = "prisma-client"
  output   = "./src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


enum Role{
  ADMIN
  DOCTOR
  RECEPTION
  SUPERADMIN
}
model User{
  id String @id @default(uuid())
  username String @unique
  password String 
  role Role @default(RECEPTION)
}
